# ── Hermes Public Concierge ──────────────────────────────────
# Copy to .env and fill in:  cp .env.example .env

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# AI Provider (at least one key required)
ANTHROPIC_API_KEY=
NOUS_API_KEY=

# Model config (defaults to claude-opus-4-6 on anthropic)
HERMES_MODEL=
HERMES_PROVIDER=
