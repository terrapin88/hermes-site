# ── Hermes Onboarding Site Configuration ─────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your domain (Caddy auto-provisions HTTPS via Let's Encrypt)
DOMAIN=yourdomain.com

# AI Provider API Keys (at least one required)
# Using Anthropic credits first, then switching to Nous Portal
ANTHROPIC_API_KEY=sk-ant-...
NOUS_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# Model configuration (optional - uses provider defaults if blank)
# HERMES_MODEL=claude-opus-4-6
# HERMES_PROVIDER=anthropic
