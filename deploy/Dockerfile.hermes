FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# Install just the deps we need (no hermes-agent, no gateway)
RUN pip install --no-cache-dir flask openai gunicorn

# Create non-root user
RUN useradd -m -s /bin/bash hermes
USER hermes
WORKDIR /home/hermes

# Copy server and prompt
COPY --chown=hermes:hermes webhook_server.py /home/hermes/webhook_server.py
COPY --chown=hermes:hermes concierge-prompt.md /home/hermes/.hermes/concierge-prompt.md

EXPOSE 8644

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8644/health || exit 1

CMD ["gunicorn", "--bind", "0.0.0.0:8644", "--workers", "2", "--timeout", "120", "webhook_server:app"]
